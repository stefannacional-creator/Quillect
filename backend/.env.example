# Backend environment variables
# Copy this file to .env and fill in your values.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# 'xai'  → xAI Grok  (https://x.ai)
# 'groq' → Groq LLaMA (https://console.groq.com)
LLM_PROVIDER=groq

# ── GROQ ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=groq-your-key-here
# LLM_MODEL=groq-3-mini        # override default model

# ── Groq LLaMA ───────────────────────────────────────────────────────────────
# Uncomment and set if using LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your-key-here
# LLM_MODEL=llama-3.3-70b-versatile
